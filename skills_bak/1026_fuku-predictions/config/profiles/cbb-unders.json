  "risk": {
    "bet_size_dollars": 2.0,
    "sizing_method": "flat",
    "max_daily_bets": 6,
    "max_daily_loss_dollars": 8.0,
    "max_single_bet_dollars": 3.0,
    "max_exposure_per_game": 3.0
