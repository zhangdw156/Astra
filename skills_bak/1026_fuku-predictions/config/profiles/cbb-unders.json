{
  "name": "CBB Unders Specialist",
  "description": "Targets college basketball unders — letdown spots, defensive matchups, slow tempo games",

  "sports": {
    "cbb": { "enabled": true, "weight": 2.0 },
    "nba": { "enabled": false },
    "nhl": { "enabled": false },
    "soccer": { "enabled": false }
  },

  "situations": {
    "letdown_spots": { "enabled": true, "boost": 1.5 },
    "back_to_back": { "enabled": true, "boost": 1.3 },
    "conference_games": { "enabled": true, "boost": 1.2 },
