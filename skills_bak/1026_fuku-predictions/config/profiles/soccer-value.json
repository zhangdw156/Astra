{
  "name": "Soccer Value Finder",
  "description": "European football focus — xG edges, BTTS, over/under goals across top leagues",

  "sports": {
    "cbb": { "enabled": false },
    "nba": { "enabled": false },
    "nhl": { "enabled": false },
    "soccer": { "enabled": true, "weight": 2.0, "leagues": ["EPL", "ESP", "GER", "ITA", "FRA", "UCL"] }
  },

  "situations": {
    "home_dogs": { "enabled": true, "boost": 1.3, "_comment": "Home pitch advantage undervalued in soccer" }
  },

  "stats": {
    "min_fpr_gap": 0,
    "defense_matters": true,
    "over_under_trends": { "bias": "any", "min_trend_games": 0 }
  },

  "players": {
    "fpr_matchup_check": false,
    "props_enabled": true,
    "prop_types": ["goals", "shots"]
  },

  "market_types": {
    "spreads": true,
    "totals": true,
    "moneylines": true,
    "player_props": true,
    "btts": true
  },

  "edge_requirements": {
    "spread_min_edge": 12.0,
    "total_min_edge": 10.0,
    "ml_min_edge": 15.0,
    "global_min_edge": 8.0
  },

  "risk": {
    "bet_size_dollars": 2.0,
    "sizing_method": "flat",
    "max_daily_bets": 6,
    "max_daily_loss_dollars": 8.0,
    "max_single_bet_dollars": 4.0,
    "max_exposure_per_game": 4.0
  },

  "presentation": {
    "show_model_reasoning": true,
    "show_player_data": true,
    "show_team_stats": true,
    "max_opportunities": 5,
    "tiers": true
  }
