{
  "name": "Sharp Spread Sniper",
  "description": "Spreads only — targets ATS value with FPR mismatches and situational edges",

  "sports": {
    "cbb": { "enabled": true, "weight": 2.0 },
    "nba": { "enabled": true, "weight": 1.0 },
    "nhl": { "enabled": false },
    "soccer": { "enabled": false }
  },

  "situations": {
    "home_dogs": { "enabled": true, "boost": 1.4, "_comment": "Home dogs cover at ~55% historically" },
    "road_favorites": { "enabled": true, "boost": 0.8, "_comment": "Road chalk underperforms" },
    "revenge_games": { "enabled": true, "boost": 1.3 },
    "trap_games": { "enabled": true, "boost": 1.3 },
    "close_spread": { "enabled": true, "boost": 1.2, "_comment": "Model has highest ATS edge on close lines" }
  },

  "stats": {
    "min_fpr_gap": 20,
    "defense_matters": true,
    "shooting_splits": true,
    "ats_trends": { "min_cover_pct": 52, "streak_direction": "covering", "min_streak": 2 }
  },

  "players": {
    "fpr_matchup_check": true,
    "min_player_fpr_gap": 20,
    "injury_awareness": true,
    "props_enabled": false
  },

  "market_types": {
    "spreads": true,
    "totals": false,
    "moneylines": false,
    "player_props": false
  },

  "edge_requirements": {
    "spread_min_edge": 8.0,
    "global_min_edge": 5.0
  },

  "risk": {
    "bet_size_dollars": 3.0,
    "sizing_method": "kelly",
    "kelly_fraction": 0.2,
    "max_daily_bets": 8,
    "max_daily_loss_dollars": 12.0,
    "max_single_bet_dollars": 5.0,
    "max_exposure_per_game": 5.0
  },

  "presentation": {
    "show_model_reasoning": true,
    "show_player_data": true,
    "show_team_stats": true,
    "max_opportunities": 5,
    "tiers": false
  }
}
