[submodule "skillshub/ComposioHQ_awesome-claude-skills"]
	path = skillshub/ComposioHQ_awesome-claude-skills
	url = https://github.com/ComposioHQ/awesome-claude-skills

[submodule "skillshub/ZhanlinCui_Agent-Skills-Hunter"]
	path = skillshub/ZhanlinCui_Agent-Skills-Hunter
	url = https://github.com/ZhanlinCui/Agent-Skills-Hunter

[submodule "skillshub/openclaw_skills"]
	path = skillshub/openclaw_skills
	url = https://github.com/openclaw/skills
	# 上游仓库同一目录下存在 PROTOCOL.md 与 protocol.md 等大小写不同同名文件，
	# 在 macOS 不区分大小写文件系统上无法同时满足，子模块会一直显示 modified content。
	ignore = dirty

[submodule "skillshub/openai_skills"]
	path = skillshub/openai_skills
	url = https://github.com/openai/skills

[submodule "skillshub/BankrBot_skills"]
	path = skillshub/BankrBot_skills
	url = https://github.com/BankrBot/skills
