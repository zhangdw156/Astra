          "reason": {
            "type": "string",
            "description": "Reason for reopening"
          }
        },
        "required": [
          "issue_id"
        ]
      }
    },
    {
      "name": "add_sla",
      "description": "Create a new Service Level Agreement (SLA) with response and resolution time targets by priority. Use this to define response/resolution time targets for different priority levels. Required: --name and --priorities (JSON). Priorities JSON format: {'response_times': {'low': '48', ...}, 'resolution_times': {'low': '120', ...}}. Related: list-slas to view all SLAs, add-issue to apply SLA to issues.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "SLA name (required)"
          },
          "priorities": {
            "type": "string",
            "description": "JSON string with response_times and resolution_times by priority (required)"
          },
          "working_hours": {
            "type": "string",
            "description": "Working hours configuration"
          },
          "is_default": {
            "type": "string",
            "enum": [
              "0",
              "1"
            ],
            "description": "Set as default SLA"
          }
        },
        "required": [
          "name",
          "priorities"
        ]
      }
    },
