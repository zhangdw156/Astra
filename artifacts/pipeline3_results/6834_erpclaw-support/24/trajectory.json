        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "description": "Issue subject/title (required)"
          },
          "customer_id": {
            "type": "string",
            "description": "Customer ID"
          },
          "item_id": {
            "type": "string",
            "description": "Item/product ID"
          },
          "serial_number_id": {
            "type": "string",
            "description": "Serial number ID"
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "description": "Issue priority"
          },
          "issue_type": {
            "type": "string",
            "enum": [
              "bug",
              "feature_request",
              "question",
              "complaint",
              "return"
            ],
            "description": "Type of issue"
          },
          "description": {
            "type": "string",
            "description": "Detailed description"
          },
          "assigned_to": {
            "type": "string",
            "description": "Employee ID to assign to"
          },
          "sla_id": {
            "type": "string",
            "description": "SLA ID to apply"
          }
        },
        "required": [
          "subject"
        ]
      }
    },
    {
