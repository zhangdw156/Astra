    {
      "name": "add_issue_comment",
      "description": "Add a comment/note to an existing support issue. Use this to add tracking notes, customer communications, or internal notes. The first employee comment triggers SLA response time tracking. Required: --issue-id and --comment. Related: get-issue to view all comments, list-issues to find issue IDs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_id": {
            "type": "string",
            "description": "Issue ID to add comment to (required)"
          },
          "comment": {
            "type": "string",
            "description": "Comment text (required)"
          },
          "comment_by": {
            "type": "string",
            "enum": [
              "employee",
              "customer"
            ],
            "description": "Who is adding the comment"
          },
          "is_internal": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "Internal comment (1) or customer-visible (0)"
          }
        },
        "required": [
          "issue_id",
          "comment"
        ]
      }
    },
    {
      "name": "resolve_issue",
      "description": "Mark a support issue as resolved with resolution notes. Use this when the issue has been fixed/completed. The system will check for SLA breach. Required: --issue-id. NOTE: This sets the resolved_at timestamp - confirm before executing. Related: reopen-issue to reopen, list-issues to verify status.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_id": {
            "type": "string",
            "description": "Issue ID to resolve (required)"
          },
          "resolution_notes": {
            "type": "string",
            "description": "Resolution description/notes"
          }
        },
        "required": [
          "issue_id"
        ]
      }
    },
    {
      "name": "reopen_issue",
      "description": "Reopen a previously resolved or closed support issue. Use this when the issue resurfaces or wasn't fully resolved. Required: --issue-id. NOTE: Confirm before executing. Related: resolve-issue to close, get-issue to check current status.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_id": {
            "type": "string",
            "description": "Issue ID to reopen (required)"
