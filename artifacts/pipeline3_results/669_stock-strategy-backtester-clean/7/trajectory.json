  "tools": [
    {
      "name": "run_backtest",
      "description": "Run a backtest for stock trading strategies (SMA crossover, RSI mean reversion, or breakout) on historical OHLCV CSV data. Use this to evaluate strategy performance including win rate, return, CAGR, drawdown, Sharpe ratio, and trade logs. Supports transaction cost modeling via commission and slippage. For quick automation, use --quiet to get JSON-only output.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "csv": {
            "type": "string",
            "description": "Path to CSV file with Date and Close columns (OHLCV data)"
          },
          "strategy": {
            "type": "string",
            "enum": [
              "sma-crossover",
              "rsi-reversion",
              "breakout"
            ],
            "default": "sma-crossover",
            "description": "Strategy logic: 'sma-crossover' for trend-following, 'rsi-reversion' for mean reversion, 'breakout' for price breakout"
          },
          "fast-window": {
            "type": "integer",
            "default": 20,
            "description": "Fast SMA window (for sma-crossover strategy)"
          },
          "slow-window": {
            "type": "integer",
            "default": 60,
            "description": "Slow SMA window (for sma-crossover strategy)"
          },
          "rsi-period": {
            "type": "integer",
            "default": 14,
            "description": "RSI period (for rsi-reversion strategy)"
          },
          "rsi-entry": {
            "type": "number",
            "default": 30,
            "description": "RSI entry threshold - buy when RSI below this (for rsi-reversion strategy)"
          },
          "rsi-exit": {
            "type": "number",
            "default": 55,
            "description": "RSI exit threshold - sell when RSI above this (for rsi-reversion strategy)"
          },
          "lookback": {
            "type": "integer",
            "default": 20,
            "description": "Lookback period for breakout detection (for breakout strategy)"
          },
          "commission-bps": {
            "type": "number",
            "default": 5,
            "description": "Commission in basis points (e.g., 5 = 0.05%)"
          },
          "slippage-bps": {
            "type": "number",
            "default": 2,
            "description": "Slippage in basis points (e.g., 2 = 0.02%)"
          },
          "initial-capital": {
            "type": "number",
            "default": 100000,
            "description": "Initial capital for backtest"
          },
          "risk-free-rate": {
            "type": "number",
            "default": 0.02,
            "description": "Risk-free rate for Sharpe ratio calculation (annual)"
          },
          "quiet": {
            "type": "boolean",
            "default": false,
            "description": "Suppress human-readable output and return JSON only"
          }
        },
        "required": [
          "csv",
          "strategy"
        ]
      }
    }
  ],
