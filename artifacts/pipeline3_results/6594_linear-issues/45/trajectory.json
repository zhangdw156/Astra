      "inputSchema": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string",
            "description": "Team ID (required). Use list_teams to find team IDs."
          },
          "title": {
            "type": "string",
            "description": "Issue title (required). A brief summary of the issue."
          },
          "description": {
            "type": "string",
            "description": "Issue description with details, steps to reproduce, or context."
          },
          "priority": {
            "type": "integer",
            "description": "Priority level: 0=none, 1=urgent, 2=high, 3=normal, 4=low",
