  "tools": [
    {
      "name": "future_value",
      "description": "Calculate future value of an investment with compound interest. Use this for investment growth projections, savings account growth, and retirement planning. For comparing multiple rates and periods, use future_value_table instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "principal": {
            "type": "number",
            "description": "Initial investment amount"
          },
          "rate": {
            "type": "number",
            "description": "Annual interest rate as decimal (e.g., 0.05 for 5%)"
          },
          "years": {
            "type": "integer",
            "description": "Number of years for the investment"
          },
          "compound_frequency": {
            "type": "integer",
            "description": "Compounding frequency per year: 1=annual, 4=quarterly, 12=monthly, 365=daily",
            "default": 1
          }
        },
        "required": [
          "principal",
          "rate",
          "years"
        ]
      }
    },
    {
      "name": "present_value",
      "description": "Calculate present value (current worth) of a future amount. Use this for loan valuation, bond pricing, and investment analysis. For comparing multiple scenarios, use future_value_table with different periods and rates instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "future_value": {
            "type": "number",
            "description": "Future amount to be discounted"
          },
          "rate": {
            "type": "number",
            "description": "Annual discount rate as decimal (e.g., 0.05 for 5%)"
          },
          "years": {
            "type": "integer",
            "description": "Number of years until the amount is received"
          },
          "compound_frequency": {
            "type": "integer",
            "description": "Compounding frequency per year: 1=annual, 4=quarterly, 12=monthly, 365=daily",
            "default": 1
          }
        },
        "required": [
          "future_value",
          "rate",
          "years"
        ]
      }
    },
    {
      "name": "discount",
      "description": "Calculate final price after applying a percentage discount. Use this for retail pricing, sale calculations, and cost savings analysis. For comparing multiple discount percentages, use discount_table instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number",
            "description": "Original price before discount"
          },
          "discount": {
            "type": "number",
            "description": "Discount percentage (e.g., 20 for 20% or 0.20 as decimal, depending on input format)"
          }
        },
        "required": [
          "price",
          "discount"
        ]
      }
    },
    {
      "name": "markup",
      "description": "Calculate selling price from cost and markup percentage. Use this for product pricing, profit margin calculation, and business pricing strategy. For comparing multiple markup scenarios, use discount_table which also shows profit margins.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "cost": {
            "type": "number",
            "description": "Cost price of the product"
          },
          "markup": {
            "type": "number",
            "description": "Markup percentage (e.g., 30 for 30% or 0.30 as decimal, depending on input format)"
          }
        },
        "required": [
          "cost",
          "markup"
        ]
      }
    },
    {
      "name": "future_value_table",
      "description": "Generate a comparison table of future values across multiple interest rates and time periods. Use this for investment scenario comparison, rate shopping, and long-term planning. For single calculations, use future_value instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "principal": {
            "type": "number",
            "description": "Initial investment amount"
          },
          "rates": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Interest rates as decimals (e.g., [0.03, 0.05, 0.07] for 3%, 5%, 7%)"
          },
          "periods": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Time periods in years to compare (e.g., [1, 5, 10, 20])"
          }
        },
        "required": [
          "principal",
          "rates",
          "periods"
        ]
      }
    },
    {
      "name": "discount_table",
      "description": "Compare multiple discount percentages for the same price. Use this for bulk pricing strategies, promotional planning, and price comparison. For single discount calculations, use discount instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number",
            "description": "Original price before discount"
          },
          "discounts": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Discount percentages to compare (e.g., [10, 15, 20, 25, 30])"
          }
        },
        "required": [
          "price",
          "discounts"
        ]
      }
    },
    {
      "name": "launch_ui",
      "description": "Launch the interactive web UI for the financial calculator. Use this for visual, tab-based calculations with real-time results and beautiful gradient UI. For command-line calculations, use the individual calculation tools instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "port": {
            "type": "integer",
            "default": 5050,
            "description": "Port number for the web server (default: 5050)"
          }
        },
        "required": []
      }
    }
