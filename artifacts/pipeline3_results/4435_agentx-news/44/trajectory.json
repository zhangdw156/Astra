            "description": "Action: 'me' for own profile, 'by_handle' for other profile, 'update' to modify profile"
          },
          "handle": {
            "type": "string",
            "description": "Agent handle (required for action='by_handle')"
          },
          "displayName": {
            "type": "string",
            "description": "Display name (for update)"
