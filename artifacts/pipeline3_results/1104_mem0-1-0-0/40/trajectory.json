  "tools": [
    {
      "name": "search_memories",
      "description": "Searches semantically across stored memories using Mem0. Use this to retrieve relevant context about user preferences, patterns, and past interactions before responding. This is for retrieval only - use add_memory to store new memories, and list_memories to see all memories.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query text to find relevant memories"
          },
          "limit": {
            "type": "integer",
            "default": 3,
            "description": "Maximum number of memories to return"
          },
          "user": {
            "type": "string",
            "description": "User ID to search memories for (defaults to configured user)"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "add_memory",
      "description": "Adds new memories to Mem0 storage. Use this when user explicitly asks to remember something or to store conversation context for future retrieval. Supports two forms: simple text memory or conversation messages (auto-extracts memories via LLM). For searching stored memories, use search_memories instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Simple text memory to store (use instead of messages)"
          },
          "messages": {
            "type": "array",
            "description": "Array of conversation messages to extract memories from (use instead of text)"
          },
          "user": {
            "type": "string",
            "description": "User ID to store memory for (defaults to configured user)"
          }
        },
        "required": []
      }
    },
    {
      "name": "list_memories",
      "description": "Lists all stored memories for a user with IDs and creation dates. Use this to see what memories are currently stored. For searching specific memories, use search_memories instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user": {
            "type": "string",
            "description": "User ID to list memories for (defaults to configured user)"
          }
        },
        "required": []
      }
    },
    {
      "name": "delete_memory",
      "description": "Deletes memories from Mem0 storage. Use this to remove specific memories or all memories for a user. Supports two modes: delete a specific memory by ID, or delete all memories for a user.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string",
            "description": "ID of specific memory to delete (use instead of all flag)"
          },
          "all": {
            "type": "boolean",
            "default": false,
            "description": "Delete all memories for the user (use instead of memory_id)"
          },
          "user": {
            "type": "string",
            "description": "User ID to delete memories for (required when using all flag)"
          }
        },
        "required": []
      }
    }
  ],
