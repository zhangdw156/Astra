  "tools": [
    {
      "name": "send_message",
      "description": "Send SMS/MMS message via Telnyx. Use this to send text messages to phone numbers. For listing messages, use list_messages instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender phone number (must be a Telnyx number you own)"
          },
          "to": {
            "type": "string",
            "description": "Recipient phone number"
          },
          "text": {
            "type": "string",
            "description": "Message text content"
          }
        },
        "required": [
          "from",
          "to",
          "text"
        ]
      }
    },
    {
      "name": "list_messages",
      "description": "List sent and received SMS/MMS messages. Use this to view message history. For sending new messages, use send_message instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "page_size": {
            "type": "integer",
            "default": 25,
            "description": "Number of messages to return per page"
          }
        },
        "required": []
      }
    },
    {
      "name": "create_call",
      "description": "Create an outbound voice call via Telnyx. Use this to initiate phone calls. For listing active calls, use list_calls; for getting call details, use get_call.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Caller ID (Telnyx phone number)"
          },
          "to": {
            "type": "string",
            "description": "Recipient phone number"
          },
          "connection_id": {
            "type": "string",
            "description": "SIP connection ID for routing the call"
          }
        },
        "required": [
          "from",
          "to",
          "connection_id"
        ]
      }
    },
    {
      "name": "list_calls",
      "description": "List all active and recent calls. Use this to monitor ongoing calls. For creating new calls, use create_call; for call details, use get_call.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "get_call",
      "description": "Get details of a specific call by ID. Use this to retrieve call status and metadata. For listing all calls, use list_calls instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Call ID to retrieve"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "hangup_call",
      "description": "Hang up an active call by ID. Use this to terminate ongoing calls. For listing calls, use list_calls.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Call ID to hang up"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "list_numbers",
      "description": "List phone numbers associated with your Telnyx account. Use this to view owned numbers. For searching available numbers to purchase, use search_numbers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "page_size": {
            "type": "integer",
            "default": 25,
            "description": "Number of numbers to return per page"
          }
        },
        "required": []
      }
    },
    {
      "name": "search_numbers",
      "description": "Search for available phone numbers to purchase. Use this to find numbers before ordering. For viewing your owned numbers, use list_numbers; for purchasing, use order_number.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "country_code": {
            "type": "string",
            "default": "US",
            "description": "Country code to search in"
          },
          "limit": {
            "type": "integer",
            "default": 10,
            "description": "Maximum number of results to return"
          }
        },
        "required": []
      }
    },
    {
      "name": "order_number",
      "description": "Order/purchase phone numbers from Telnyx. Use this to buy available numbers. For searching available numbers, use search_numbers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "phone_numbers": {
            "type": "string",
            "description": "JSON array of phone numbers to order (e.g., [+1234567890])"
          }
        },
        "required": [
          "phone_numbers"
        ]
      }
    },
    {
      "name": "list_connections",
      "description": "List all SIP connections for your Telnyx account. Use this to view available connections. For creating new connections, use create_connection.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "create_connection",
      "description": "Create a new SIP connection for voice routing. Use this to set up SIP trunking. For listing connections, use list_connections.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the connection"
          },
          "connection_type": {
            "type": "string",
            "default": "ip",
            "description": "Connection type (e.g., ip, sip)"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "send_fax",
      "description": "Send a fax via Telnyx. Use this to transmit fax documents. For listing sent faxes, use list_faxes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender fax number (Telnyx number)"
          },
          "to": {
            "type": "string",
            "description": "Recipient fax number"
          },
          "media_url": {
            "type": "string",
            "description": "URL to the fax document (PDF)"
          }
        },
        "required": [
          "from",
          "to",
          "media_url"
        ]
      }
    },
    {
      "name": "list_faxes",
