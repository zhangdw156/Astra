  "tools": [
    {
      "name": "init",
      "description": "Initialize a new paper trading account with a name, base currency, and starting balance. Use this first before any other trading commands. The account must be created before opening positions or logging snapshots.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "name": {
            "type": "string",
            "description": "Human-readable account name"
          },
          "base-currency": {
            "type": "string",
            "description": "Base currency for PnL (e.g., USD)"
          },
          "starting-balance": {
            "type": "number",
            "description": "Initial balance for the account"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path (default: ~/.openclaw/paper-trading.db)"
          }
        },
        "required": [
          "account",
          "name",
          "base-currency",
          "starting-balance"
        ]
      }
    },
    {
      "name": "snapshot",
      "description": "Log a market snapshot for a symbol to enable unrealized PnL tracking. Use this to record current prices for open positions. Required for the status command to calculate unrealized PnL. The mint parameter is required for identifying the specific asset.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Trading symbol (e.g., BTC, ETH)"
          },
          "mint": {
            "type": "string",
            "description": "Token contract address (required for DEX tokens like WETH, WBTC/cbBTC)"
          },
          "price": {
            "type": "number",
            "description": "Current market price"
          },
          "source": {
            "type": "string",
            "description": "Price source (currently only 'dexscreener' is supported)",
            "default": "dexscreener"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "symbol",
          "mint"
        ]
      }
    },
    {
      "name": "open",
      "description": "Open a new long or short position with specified quantity, entry price, and risk management levels. Use this to start tracking a new trade. Supports stop-loss and take-profit levels along with maximum risk percentage.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "symbol": {
            "type": "string",
            "description": "Trading symbol (e.g., BTC, ETH)"
          },
          "mint": {
            "type": "string",
            "description": "Token contract address (required for DEX tokens)"
          },
          "side": {
            "type": "string",
            "enum": [
              "LONG",
              "SHORT"
            ],
            "description": "Position direction"
          },
          "qty": {
            "type": "number",
            "description": "Position size"
          },
          "price": {
            "type": "number",
            "description": "Entry price"
          },
          "fee": {
            "type": "number",
            "description": "Trading fee in base currency"
          },
          "stop-price": {
            "type": "number",
            "description": "Stop-loss price"
          },
          "take-price": {
            "type": "number",
            "description": "Take-profit price"
          },
          "max-risk-pct": {
            "type": "number",
            "description": "Maximum risk as percentage of account balance"
          },
          "note": {
            "type": "string",
            "description": "Trade thesis or notes"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "account",
          "symbol",
          "mint",
          "side",
          "qty"
        ]
      }
    },
    {
      "name": "set_levels",
      "description": "Update stop-loss and take-profit levels for an existing position. Use this to adjust risk management as the trade evolves. If multiple positions exist for the same symbol, use mint to target the correct one.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "symbol": {
            "type": "string",
            "description": "Trading symbol (e.g., BTC, ETH)"
          },
          "mint": {
            "type": "string",
            "description": "Token contract address (required if multiple positions share same symbol)"
          },
          "side": {
            "type": "string",
            "enum": [
              "LONG",
              "SHORT"
            ],
            "description": "Position direction"
          },
          "stop-price": {
            "type": "number",
            "description": "New stop-loss price"
          },
          "take-price": {
            "type": "number",
            "description": "New take-profit price"
          },
          "note": {
            "type": "string",
            "description": "Reason for level change"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "account",
          "symbol"
        ]
      }
    },
    {
      "name": "close",
      "description": "Close (or partially close) an existing position at a specified price. Use this to realize profits or losses. The qty parameter allows partial closes. If multiple positions exist for the same symbol, use mint to target the correct one.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "symbol": {
            "type": "string",
            "description": "Trading symbol (e.g., BTC, ETH)"
          },
          "mint": {
            "type": "string",
            "description": "Token contract address (required if multiple positions share same symbol)"
          },
          "side": {
            "type": "string",
            "enum": [
              "LONG",
              "SHORT"
            ],
            "description": "Position direction"
          },
          "qty": {
            "type": "number",
            "description": "Quantity to close (use full qty for full close, less for partial)"
          },
          "price": {
            "type": "number",
            "description": "Exit price"
          },
          "fee": {
            "type": "number",
            "description": "Trading fee in base currency"
          },
          "note": {
            "type": "string",
            "description": "Reason for closing"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "account",
          "symbol",
          "qty"
        ]
      }
    },
    {
      "name": "note",
      "description": "Add a journal note with optional tags for a specific position. Use this to record thesis updates, risk assessments, or macro observations. Notes are stored as immutable events for later review.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "symbol": {
            "type": "string",
            "description": "Trading symbol (e.g., BTC, ETH)"
          },
          "side": {
            "type": "string",
            "enum": [
              "LONG",
              "SHORT"
            ],
            "description": "Position direction"
          },
          "note": {
            "type": "string",
            "description": "Journal entry text"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for categorization (e.g., thesis, risk, macro)"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "account",
          "symbol",
          "note"
        ]
      }
    },
    {
      "name": "status",
      "description": "Show current portfolio status including open positions, realized PnL, and unrealized PnL. Use this to check your current exposure. Unrealized PnL requires prior snapshots. Supports JSON output with optional pretty printing.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "format": {
            "type": "string",
            "enum": [
              "text",
              "json"
            ],
            "description": "Output format (default: text)"
          },
          "pretty": {
            "type": "boolean",
            "description": "Pretty print JSON output"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "account"
        ]
      }
    },
    {
      "name": "review",
      "description": "Generate a weekly performance summary including trade statistics, win rate, and PnL breakdown. Use this at the end of each week to review performance. Supports JSON output with optional pretty printing.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account identifier (e.g., 'main')"
          },
          "format": {
            "type": "string",
            "enum": [
              "text",
              "json"
            ],
            "description": "Output format (default: text)"
          },
          "pretty": {
            "type": "boolean",
            "description": "Pretty print JSON output"
          },
          "db": {
            "type": "string",
            "description": "Optional custom database path"
          }
        },
        "required": [
          "account"
        ]
      }
    }
