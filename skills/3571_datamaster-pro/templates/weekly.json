{
  "name": "周报模板",
  "description": "适合工作周报、项目进度、团队汇报",
  "version": "1.0",
  
  "report": {
    "title": {
      "template": "{{团队名称}} - 第{{周数}}周工作周报",
      "includeDate": true,
      "dateFormat": "MM月DD日"
    },
    
    "sections": [
      {
        "name": "本周概要",
        "type": "summary",
        "required": true,
        "content": {
          "highlights": true,
          "keyAchievements": true,
          "overallStatus": true
        }
      },
      {
        "name": "工作进展",
        "type": "progress",
        "required": true,
        "content": {
          "completed": true,
          "inProgress": true,
          "blocked": true
        }
      },
      {
        "name": "数据概览",
        "type": "metrics",
        "required": true,
        "content": {
          "kpis": true,
          "trends": true,
          "comparisons": "wow"
        }
      },
      {
        "name": "问题与风险",
        "type": "issues",
        "required": false,
        "content": {
          "blockers": true,
          "risks": true,
          "needHelp": true
        }
      },
      {
        "name": "下周计划",
        "type": "plan",
        "required": true,
        "content": {
          "priorities": true,
          "deliverables": true,
          "milestones": true
        }
      }
    ]
  },
  
  "charts": {
    "progress": {
      "type": "bar",
      "title": "任务完成情况",
      "orientation": "horizontal",
      "showValues": true,
      "colors": {
        "completed": "#4CAF50",
        "inProgress": "#2196F3",
        "pending": "#9E9E9E"
      }
    },
    "trend": {
      "type": "line",
      "title": "本周趋势",
      "showTrendLine": true,
      "comparison": "wow"
    },
    "distribution": {
      "type": "pie",
      "title": "时间分配",
      "showPercentages": true
    }
  },
  
  "style": {
    "font": {
      "title": "Microsoft YaHei",
      "body": "Microsoft YaHei",
      "sizes": {
        "h1": 20,
        "h2": 16,
        "h3": 14,
        "body": 12
      }
    },
    "colors": {
      "primary": "#1976D2",
      "secondary": "#757575",
      "success": "#4CAF50",
      "warning": "#FF9800",
      "error": "#F44336",
      "background": "#FFFFFF"
    },
    "emoji": {
      "enabled": true,
      "completed": "✅",
      "inProgress": "🔄",
      "blocked": "🚫",
      "priority": "🔥"
    }
  },
  
  "output": {
    "formats": ["markdown"],
    "includeTimestamp": true,
    "compact": true
  },
  
  "automation": {
    "dataSource": {
      "type": "auto",
      "sources": ["jira", "github", "notion"],
      "sync": true
    },
    "reminders": {
      "enabled": true,
      "dayOfWeek": 5,
      "time": "17:00"
    }
  }
}