{
  "name": "商业分析报告",
  "description": "适合销售报告、市场分析、经营决策",
  "version": "1.0",
  
  "report": {
    "title": {
      "template": "{{公司名称}} - {{报告类型}}报告",
      "includeDate": true,
      "dateFormat": "YYYY年MM月DD日"
    },
    
    "sections": [
      {
        "name": "执行摘要",
        "type": "summary",
        "required": true,
        "content": {
          "keyMetrics": true,
          "highlights": true,
          "recommendations": true
        }
      },
      {
        "name": "数据分析",
        "type": "analysis",
        "required": true,
        "content": {
          "trends": true,
          "comparisons": true,
          "correlations": true
        }
      },
      {
        "name": "可视化图表",
        "type": "charts",
        "required": true,
        "content": {
          "mainChart": "bar",
          "secondaryChart": "line",
          "pieChart": true
        }
      },
      {
        "name": "洞察与建议",
        "type": "insights",
        "required": true,
        "content": {
          "aiInsights": true,
          "actionItems": true,
          "risks": true
        }
      },
      {
        "name": "附录",
        "type": "appendix",
        "required": false,
        "content": {
          "rawData": false,
          "methodology": true,
          "glossary": false
        }
      }
    ]
  },
  
  "charts": {
    "main": {
      "type": "bar",
      "title": "主要数据趋势",
      "colors": ["#4CAF50", "#2196F3", "#FF9800", "#9C27B0"],
      "width": 800,
      "height": 400
    },
    "secondary": {
      "type": "line",
      "title": "变化趋势",
      "showTrendLine": true,
      "showDataPoints": true
    },
    "pie": {
      "type": "pie",
      "title": "占比分布",
      "showPercentages": true,
      "showLegend": true
    }
  },
  
  "style": {
    "font": {
      "title": "Microsoft YaHei",
      "body": "Microsoft YaHei",
      "sizes": {
        "h1": 24,
        "h2": 18,
        "h3": 14,
        "body": 12
      }
    },
    "colors": {
      "primary": "#1976D2",
      "secondary": "#424242",
      "accent": "#4CAF50",
      "background": "#FFFFFF",
      "text": "#212121"
    },
    "spacing": {
      "paragraph": 1.5,
      "section": 2
    }
  },
  
  "output": {
    "formats": ["markdown", "html", "pdf"],
    "includeTableOfContents": true,
    "includePageNumbers": true,
    "chartEmbed": true
  },
  
  "aiInsights": {
    "enabled": true,
    "language": "zh-CN",
    "tone": "professional",
    "includeRecommendations": true,
    "maxInsights": 5
  }
}