{
  "name": "技术数据报告",
  "description": "适合性能分析、系统监控、技术指标报告",
  "version": "1.0",
  
  "report": {
    "title": {
      "template": "{{项目名称}} - 技术分析报告",
      "includeDate": true,
      "dateFormat": "YYYY-MM-DD"
    },
    
    "sections": [
      {
        "name": "概述",
        "type": "overview",
        "required": true,
        "content": {
          "purpose": true,
          "scope": true,
          "methodology": true
        }
      },
      {
        "name": "数据采集",
        "type": "collection",
        "required": true,
        "content": {
          "source": true,
          "timeRange": true,
          "sampleSize": true,
          "dataQuality": true
        }
      },
      {
        "name": "统计分析",
        "type": "statistics",
        "required": true,
        "content": {
          "descriptive": true,
          "distributions": true,
          "correlations": true,
          "anomalies": true
        }
      },
      {
        "name": "性能指标",
        "type": "metrics",
        "required": true,
        "content": {
          "kpis": true,
          "benchmarks": true,
          "trends": true,
          "percentiles": true
        }
      },
      {
        "name": "问题诊断",
        "type": "diagnosis",
        "required": false,
        "content": {
          "anomalies": true,
          "rootCause": true,
          "impact": true
        }
      },
      {
        "name": "结论与建议",
        "type": "conclusion",
        "required": true,
        "content": {
          "findings": true,
          "recommendations": true,
          "nextSteps": true
        }
      }
    ]
  },
  
  "charts": {
    "performance": {
      "type": "line",
      "title": "性能趋势",
      "showPercentiles": ["p50", "p90", "p99"],
      "colors": ["#2196F3", "#4CAF50", "#FF9800"],
      "width": 900,
      "height": 350
    },
    "distribution": {
      "type": "histogram",
      "title": "数据分布",
      "bins": 20,
      "showNormalCurve": true
    },
    "heatmap": {
      "type": "heatmap",
      "title": "相关性矩阵",
      "showValues": true,
      "colorScale": "RdYlGn"
    },
    "boxplot": {
      "type": "box",
      "title": "数据分布箱线图",
      "showOutliers": true
    }
  },
  
  "style": {
    "font": {
      "title": "Consolas",
      "body": "Microsoft YaHei",
      "code": "Source Code Pro",
      "sizes": {
        "h1": 22,
        "h2": 16,
        "h3": 14,
        "body": 11,
        "code": 10
      }
    },
    "colors": {
      "primary": "#1976D2",
      "secondary": "#455A64",
      "accent": "#00BCD4",
      "background": "#FAFAFA",
      "text": "#212121",
      "code": "#37474F",
      "codeBackground": "#ECEFF1"
    },
    "code": {
      "highlight": true,
      "lineNumbers": true,
      "theme": "light"
    }
  },
  
  "output": {
    "formats": ["markdown", "html"],
    "includeTableOfContents": true,
    "includeTimestamps": true,
    "chartEmbed": true,
    "rawDataAppendix": true
  },
  
  "aiInsights": {
    "enabled": true,
    "language": "zh-CN",
    "tone": "technical",
    "includeRecommendations": true,
    "focusAreas": ["performance", "reliability", "scalability"]
  }
}